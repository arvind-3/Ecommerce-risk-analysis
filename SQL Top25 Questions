#1.
Find the total number of orders.
SELECT COUNT(*) AS total_orders
FROM customer_shopping;
#2. 
Calculate the total revenue generated.

SELECT SUM(order_value_eur) AS total_revenue
FROM customer_shopping;
#3
Find the average order value.

SELECT AVG(order_value_eur) AS avg_order_value
FROM customer_shopping;
#4.
Display the top 10 highest-value orders.

SELECT order_id, order_value_eur
FROM customer_shopping
ORDER BY order_value_eur DESC
LIMIT 10;
#5. 
Calculate revenue generated by each country.

SELECT country,
       SUM(order_value_eur) AS revenue
FROM customer_shopping
GROUP BY country
ORDER BY revenue DESC;
#6.
Count total orders in each product category.

SELECT product_category,
       COUNT(*) AS total_orders
FROM customer_shopping
GROUP BY product_category
ORDER BY total_orders DESC;
#7.
Find revenue generated by each product category.

SELECT product_category,
       SUM(order_value_eur) AS revenue
FROM customer_shopping
GROUP BY product_category
ORDER BY revenue DESC;
#8.
Find the most used payment method.

SELECT payment_method,
       COUNT(*) AS usage_count
FROM customer_shopping
GROUP BY payment_method
ORDER BY usage_count DESC;
#9.
Calculate the fraud rate percentage.

SELECT ROUND(
       100.0 * SUM(is_fraud) / COUNT(*),2
       ) AS fraud_rate
FROM customer_shopping;
#10.
Find the total number of fraudulent orders.

SELECT COUNT(*) AS fraud_orders
FROM customer_shopping
WHERE is_fraud = 1;
#11.
Identify countries with the highest fraud cases.

SELECT country,
       COUNT(*) AS fraud_cases
FROM customer_shopping
WHERE is_fraud = 1
GROUP BY country
ORDER BY fraud_cases DESC;
#12. 
Find fraud cases by payment method.

SELECT payment_method,
       COUNT(*) AS fraud_cases
FROM customer_shopping
WHERE is_fraud = 1
GROUP BY payment_method
ORDER BY fraud_cases DESC;
#13.
Calculate the return rate percentage.

SELECT ROUND(
       100.0 * SUM(is_returned) / COUNT(*),2
       ) AS return_rate
FROM customer_shopping;
#14. 
Find total returned orders.

SELECT COUNT(*) AS returned_orders
FROM customer_shopping
WHERE is_returned = 1;
15
#Find returned orders by category.

SELECT product_category,
       COUNT(*) AS returns_count
FROM customer_shopping
WHERE is_returned = 1
GROUP BY product_category
ORDER BY returns_count DESC;
#16. 
Calculate average discount for each category.

SELECT product_category,
       AVG(discount_percent) AS avg_discount
FROM customer_shopping
GROUP BY product_category;

#17. 
Analyze monthly revenue.

SELECT MONTH(order_date) AS month,
       SUM(order_value_eur) AS revenue
FROM customer_shopping
GROUP BY MONTH(order_date)
ORDER BY month;

#18. 
Find the top 5 customers based on total spending.

SELECT customer_id,
       SUM(order_value_eur) AS total_spent
FROM customer_shopping
GROUP BY customer_id
ORDER BY total_spent DESC
LIMIT 5;
#19. 
Count orders by risk label.
SELECT risk_label,
       COUNT(*) AS total_orders
FROM customer_shopping
GROUP BY risk_label
ORDER BY total_orders DESC;

#20. High-Risk Orders
Find all high-risk orders.
SELECT *
FROM customer_shopping
WHERE risk_label = 'High Risk';
